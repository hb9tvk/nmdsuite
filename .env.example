# Copy to .env and adjust for your environment.

# --- Django ---
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=replace-me-with-a-long-random-string
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_TIME_ZONE=UTC
DJANGO_LANGUAGE_CODE=de

# --- Database ---
# Leave NMD_DB_PATH unset for local dev; settings.py will use <repo>/data/nmdsuite.sqlite3.
# For Docker, the compose file already overrides this to /data/nmdsuite.sqlite3 inside
# the container (mounted as the nmd_data volume).
# NMD_DB_PATH=/data/nmdsuite.sqlite3

# --- Email / SMTP ---
# SMTP_USER and SMTP_PASSWORD are optional.
# Leave them empty to use anonymous relay (e.g. internal mail server on port 25).
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=false
SMTP_USE_SSL=false
DEFAULT_FROM_EMAIL=nmd@uska.ch

# --- Public URL (used in password reset and registration confirmation emails) ---
NMD_BASE_URL=http://localhost:8000

# --- Swisstopo (optional; the public WMTS layer needs no key today) ---
SWISSTOPO_HEIGHT_API=https://api3.geo.admin.ch/rest/services/height
